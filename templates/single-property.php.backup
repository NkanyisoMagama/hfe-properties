                                    <path d="M3 10c0-3.86 3.14-7 7-7 .55 0 1 .45 1 1s-.45 1-1 1c-2.76 0-5 2.24-5 5H3zm18 7H3v3h18v-3zm0-3c.55 0 1-.45 1-1s-.45-1-1-1H3c-.55 0-1 .45-1 1s.45 1 1 1h18z"/>
