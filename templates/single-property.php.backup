                    </svg>
                    <strong><?php _e('Status:', 'hfe-properties'); ?></strong>
                    <span class="hfe-status-badge-inline <?php echo esc_attr('hfe-status-' . $meta['status']); ?>">
                        <?php echo $meta['status'] === 'rent' ? __('For Rent', 'hfe-properties') : __('For Sale', 'hfe-properties'); ?>
