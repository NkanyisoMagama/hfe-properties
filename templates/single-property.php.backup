                            <path d="M10 0C4.48 0 0 4.48 0 10s4.48 10 10 10 10-4.48 10-10S15.52 0 10 0zm1.41 16.09V18h-2.67v-1.93c-1.71-.36-3.16-1.46-3.27-3.4h1.96c.1 1.05.82 1.87 2.65 1.87 1.96 0 2.4-.98 2.4-1.59 0-.83-.44-1.61-2.67-2.14-2.48-.6-4.18-1.62-4.18-3.67 0-1.72 1.39-2.84 3.11-3.21V2h2.67v1.95c1.86.45 2.79 1.86 2.85 3.39H14.3c-.05-1.11-.64-1.87-2.22-1.87-1.5 0-2.4.68-2.4 1.64 0 .84.65 1.39 2.67 1.91s4.18 1.39 4.18 3.91c-.01 1.83-1.38 2.83-3.12 3.16z"/>
                        </svg>
                        <strong><?php _e('Price:', 'hfe-properties'); ?></strong>
                        <span class="hfe-price-large"><?php echo hfe_get_property_price($property_id); ?></span>
                    </div>
                <?php endif; ?>
            </div>
        </div>
    </div>

    <div class="hfe-container">
        <div class="hfe-property-layout">
            <div class="hfe-property-main-content">

                <!-- Property Stats -->
                <div class="hfe-property-stats">
